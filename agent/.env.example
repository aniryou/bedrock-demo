# Copy to .env (gitignored).

# ── Model (Amazon Bedrock) ─────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-opus-4-8
AWS_REGION=us-west-2
MAX_TOKENS=2048

# ── AgentCore capabilities (required — Gateway-only runtime, no local fallback) ─
KNOWLEDGE_BASE_ID=
AGENTCORE_MEMORY_ID=
GATEWAY_URL=

# ── Inbound user identity (CUSTOM_JWT) ─────────────────────────────
USER_JWT_HEADER=Authorization

# ── Identity / skills ────────────────────────────────────────────────────────
SKILLS_REPO=aniryou/order-triage-knowledge   # `make skills` fetches skills/*.skill.md + ontology from here
SKILLS_REF=main                              # tag/branch to pin the fetch to (reproducible builds)
# SKILLS_DIR=skills
# ONTOLOGY_DIR=ontology                      # bindings.json (+ compiled ontology) for the describe_entity tool
