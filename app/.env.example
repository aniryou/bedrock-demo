# order-triage-webapp local config (per-deploy overrides).
# Shared Entra app config + the client secret are read from ../.env (bedrock-demo/.env):
#   ENTRA_TENANT_ID, ENTRA_AGENT_APP_ID, ENTRA_AGENT_CLIENT_SECRET, ENTRA_AGENT_SCOPE, AWS_REGION
# Copy this file to .env and fill in the per-deploy values below.

# The OBO runtime ARN — recreated each deploy. Get it after 
# cd ../bedrock-demo-infra && make deploy && make ingest
OBO_RUNTIME_ARN=

# Where Entra redirects back after sign-in. MUST be registered as a redirect URI
# on the Entra AGENT app (appId = ENTRA_AGENT_APP_ID), type "Web".
WEBAPP_REDIRECT_URI=http://localhost:8000/callback

# Optional overrides (otherwise inherited from ../.env):
# AWS_REGION=us-west-2
# ENTRA_AGENT_SCOPE=api://<agent-app-id>/access_as_user
