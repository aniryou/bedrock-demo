# ============================================================================
#  SINGLE config file for all deploy/ops. Copy to  bedrock-demo/.env  — the
#  PARENT dir of the cloned repos (not inside a repo) — and fill it in. That one
#  file is the only thing you copy to a new machine; everything else comes from
#  the repos. Read by the orchestrator (make deploy/status/destroy) AND by
#  bedrock-demo-infra (make snowflake-setup / bootstrap-admin). Gitignored.
#
#  (Running the AGENT locally is a separate concern — see order-triage-agent/.env.example.
#   It is NOT needed to deploy.)
# ============================================================================

# --- AWS credentials (need: bedrock, bedrock-agentcore, lambda, s3, ecr, iam, -----
#     codebuild, logs, secretsmanager). Use a scoped IAM user/role — NOT root keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- REQUIRED stub API keys (Terraform has no insecure defaults). The gateway -----
#     presents these to the SAP/orders + Snowflake stub Function URLs (auth_type=NONE,
#     which enforce only this key). Use strong random values:  openssl rand -hex 24
SAP_API_KEY=
SNOWFLAKE_API_KEY=

# --- Optional overrides (defaults shown) ------------------------------------------
# AWS_REGION=us-west-2
# BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# NAME_PREFIX=order-triage
# BEDROCK_DEMO_ROOT=/absolute/path/to/the/repos-parent-dir

# ==== Snowflake bootstrap (make snowflake-setup) ==================================
SNOWFLAKE_ACCOUNT=GA20262
SNOWFLAKE_HOST=ga20262.ap-southeast-1.snowflakecomputing.com   # <account>.<region>.snowflakecomputing.com

# Seeding-admin auth:
#   keypair   — RSA key-pair, FULLY HEADLESS (recommended; no browser). One-time setup:
#               run `make -C bedrock-demo-infra bootstrap-admin`, paste its SQL into
#               Snowsight once (creates the user + grants + registers the key), then paste
#               the SNOWFLAKE_ADMIN_USER + SNOWFLAKE_ADMIN_PRIVATE_KEY_B64 it prints. Headless after.
#   pat/oauth — token from SNOWFLAKE_ADMIN_TOKEN_FILE (PAT needs a network policy)
#   password / externalbrowser — see bedrock-demo-infra/scripts/snowflake_bootstrap.py
SNOWFLAKE_ADMIN_USER=SVC_ORDER_TRIAGE_BOOTSTRAP
SNOWFLAKE_ADMIN_AUTH=keypair
# Inline single-line base64 of the PKCS#8 PEM key (.env-safe); `make bootstrap-admin` prints it.
# Manual:  base64 < bedrock-demo-infra/snowflake/.keys/bootstrap_admin_rsa_key.p8 | tr -d '\n'
SNOWFLAKE_ADMIN_PRIVATE_KEY_B64=
# ...alternatives (paths are relative to bedrock-demo-infra/, where the script runs):
# SNOWFLAKE_ADMIN_PRIVATE_KEY=snowflake/.keys/bootstrap_admin_rsa_key.p8   # b64 wins if both set
# SNOWFLAKE_ADMIN_PRIVATE_KEY_PASSPHRASE=                                  # only if the key is encrypted
# SNOWFLAKE_ADMIN_TOKEN_FILE=../snowflake-secret.txt                       # for AUTH=pat/oauth

# Object names (optional; defaults match setup.sql). snowflake_bootstrap.py templates
# setup.sql AND writes the Secrets Manager payload from these, so override HERE (not in
# the SQL) to keep the objects, the secret, and the Lambda in sync. Keep UPPER_SNAKE_CASE.
# SNOWFLAKE_WAREHOUSE=ORDER_TRIAGE_WH
# SNOWFLAKE_DATABASE=ORDER_TRIAGE_DB
# SNOWFLAKE_RO_ROLE=ORDER_TRIAGE_RO
# SNOWFLAKE_SVC_USER=SVC_ORDER_TRIAGE
# SNOWFLAKE_SECRET_NAME=order-triage/snowflake   # must equal terraform var.snowflake_secret_name
# SNOWFLAKE_BOOTSTRAP_USER=SVC_ORDER_TRIAGE_BOOTSTRAP

# ==== CD pipeline tokens (repo->repo dispatch CD only; NOT needed for a local deploy) ====
# DISPATCH_TOKEN=github_pat_...
# SKILLS_TOKEN=github_pat_...
