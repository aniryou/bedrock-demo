# ── Secrets / local config (NEVER commit) ─────────────────────────────────────
# The single root .env is the one config file for the whole stack (infra/ + app/
# read it as ../.env). It holds AWS, Entra, and Snowflake credentials.
.env
.env.*
!.env.example

# Claude Code / local tooling state
.claude/

# ── Ignored top-level directories (not part of this repo) ─────────────────────
# Standalone clones of the components may sit at the repo root; keep them out of
# the tree so only infra/ stubs/ knowledge/ agent/ app/ are tracked.
/bedrock-demo-infra/
/bedrock-demo-stubs/
/order-triage-knowledge/
/order-triage-agent/
/order-triage-webapp/
/pull-all.sh
/mermaid-check-skill.tar.gz

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
*.swp

# ── Python (belt-and-suspenders; each folder also has its own .gitignore) ──────
__pycache__/
*.py[cod]
.venv/
.ruff_cache/
.pytest_cache/
